# ============================================================
# FARE CALCULATOR
# ============================================================

def calculate_fare(city, distance, hour, vehicle, waiting=0, surge=1.0, coupon=0):
    cfg = UP_CITIES[city]
    base = cfg['base_fare']
    dist_charge = distance * cfg['per_km']
    time_charge = (distance * 2) * cfg['per_min']
    wait_charge = waiting * 2
    subtotal = base + dist_charge + time_charge + wait_charge
    
    is_night = hour >= NIGHT_START or hour < NIGHT_END
    night_mult = cfg['night_mult'] if is_night else 1.0
    is_peak = hour in PEAK_HOURS
    peak_mult = cfg['peak_mult'] if is_peak else 1.0
    veh_mult = VEHICLE_TYPES[vehicle]
    
    fare = subtotal * night_mult * peak_mult * veh_mult * surge
    fare = max(fare, cfg['min_fare'])
    discount = fare * (coupon / 100)
    final = math.ceil(fare - discount)
    
    return {
        'base': base, 'distance_charge': round(dist_charge, 2), 'time_charge': round(time_charge, 2),
        'waiting_charge': wait_charge, 'subtotal': round(subtotal, 2), 'night_mult': night_mult,
        'peak_mult': peak_mult, 'veh_mult': veh_mult, 'surge': surge, 'fare_before': round(fare, 2),
        'coupon': coupon, 'discount': round(discount, 2), 'final_fare': final,
        'is_night': is_night, 'is_peak': is_peak
    }

# ============================================================
# DATA GENERATOR (FIXED - weights= instead of p=)
# ============================================================

def generate_data(n=5000):
    np.random.seed(42)
    random.seed(42)
    cities = list(UP_CITIES.keys())
    data = []
    
    for i in range(n):
        city = random.choice(cities)
        locs = UP_CITIES[city]['locations']
        pickup = random.choice(locs)
        dropoff = random.choice(locs)
        while dropoff == pickup:
            dropoff = random.choice(locs)
        
        ptime = datetime(2024, 1, 1) + timedelta(minutes=random.randint(0, 525600))
        hour = ptime.hour
        dist = round(min(np.random.exponential(8) + 2, 50), 2)
        veh = random.choice(list(VEHICLE_TYPES.keys()))
        wait = random.randint(0, 15)
        
        # FIXED: Use weights= instead of p=
        surge = random.choices([1.0, 1.2, 1.5, 2.0], weights=[0.6, 0.25, 0.12, 0.03])[0]
        coupon = random.choices([0, 10, 15, 20, 25], weights=[0.5, 0.2, 0.15, 0.1, 0.05])[0]
        
        fare = calculate_fare(city, dist, hour, veh, wait, surge, coupon)
        status = random.choices(['completed', 'cancelled', 'no_show'], weights=[0.78, 0.15, 0.07])[0]
        payment = random.choice(['cash', 'card', 'wallet', 'upi'])
        
        driver = f"{random.choice(DRIVER_NAMES)} {random.choice(['Kumar', 'Singh', 'Sharma'])}"
        customer = f"{random.choice(CUST_NAMES)} {random.choice(['Gupta', 'Verma', 'Patel'])}"
        
        d_rating = round(random.uniform(3.0, 5.0), 1) if status == 'completed' else None
        c_rating = round(random.uniform(3.5, 5.0), 1) if status == 'completed' else None
        duration = int(dist * random.uniform(1.5, 3.0)) + wait if status == 'completed' else None
        
        membership = random.choices(
            ['none', 'silver', 'gold', 'platinum'],
            weights=[0.5, 0.3, 0.15, 0.05]
        )[0]

        shared = random.choice([True, False])
        
        data.append({
            'ride_id': i+1, 'city': city, 'pickup': pickup, 'dropoff': dropoff,
            'pickup_time': ptime, 'hour': hour, 'distance': dist, 'vehicle': veh,
            'waiting': wait, 'surge': surge, 'coupon': coupon,
            'base_fare': fare['base'], 'distance_charge': fare['distance_charge'],
            'time_charge': fare['time_charge'], 'waiting_charge': fare['waiting_charge'],
            'subtotal': fare['subtotal'], 'night_mult': fare['night_mult'],
            'peak_mult': fare['peak_mult'], 'veh_mult': fare['veh_mult'],
            'surge_mult': fare['surge'], 'fare_before': fare['fare_before'],
            'discount': fare['discount'], 'final_fare': fare['final_fare'],
            'status': status, 'payment': payment, 'is_night': fare['is_night'],
            'is_peak': fare['is_peak'], 'driver': driver, 'driver_rating': round(random.uniform(3.5, 5.0), 1),
            'customer': customer, 'membership': membership,
            'ride_duration': duration, 'driver_ride_rating': d_rating,
            'customer_ride_rating': c_rating, 'shared': shared
        })
    
    return pd.DataFrame(data)

