VEHICLE_TYPES = {'Auto': 1.0, 'Bike': 0.7, 'Micro': 1.0, 'Mini': 1.2, 'Sedan': 1.5, 'SUV': 2.0, 'Luxury': 3.0, 'Share': 0.6}
PEAK_HOURS = [8, 9, 17, 18, 19]
NIGHT_START, NIGHT_END = 22, 6

DRIVER_NAMES = ['Rajesh', 'Amit', 'Suresh', 'Vikram', 'Rahul', 'Anil', 'Pankaj', 'Deepak', 'Manoj', 'Sanjay', 'Ravi', 'Kiran']
